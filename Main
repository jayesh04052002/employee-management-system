public class Main
{
	public static void main(String[] args)
	{
		int num = 5;
		boolean isPrime = flase;
		if(num==0 || num==1)
		{
			System.out.println("it is not a prime number");
		}
		else
		{
			for(int i=2;i<num;i++)
			{
				if(num%i==0)
				{
					isPrime=true;
					break;
				}
			}
		}
		if(!isPrime)
		{
			System.out.println("it is not a prime number");
		}
		else{
		System.out.println("it is not a prime number");
	}
}